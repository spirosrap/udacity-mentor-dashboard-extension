{
  "manifest_version": 3,
  "name": "Udacity Mentor Dashboard Tools",
  "version": "1.5.20",
  "description": "Daily income + queue auto-refresh tools for Udacity Mentor Dashboard with popup controls.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Udacity Mentor Dashboard Tools",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://mentor-dashboard.udacity.com/queue/*"
      ],
      "js": [
        "daily-income.js"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://mentor-dashboard.udacity.com/*"
      ],
      "js": [
        "auto-refresh.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    },
    {
      "matches": [
        "https://mentor-dashboard.udacity.com/*"
      ],
      "js": [
        "bridge.js"
      ],
      "run_at": "document_start"
    }
  ]
}
